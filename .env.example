# Meerkat Ops — Environment Variables
# Copy this file to .env.local and fill in your values

# Google Gemini (AI analysis)
GOOGLE_GENERATIVE_AI_API_KEY=

# Supabase (database)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ElevenLabs (voice agent)
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=

# Slack (alerts and stop command)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Twilio (optional — ElevenLabs handles calls directly)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Google Cloud Storage (optional — falls back to simulated logs)
GCS_KEY_FILE=
GCP_PROJECT_ID=
GCS_LOG_BUCKET=
